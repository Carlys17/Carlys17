# ==============================================
# LI.FI Auto Swap & Bridge Bot - Configuration
# ==============================================
# ⚠️  NEVER share your PRIVATE_KEY with anyone!
# ⚠️  NEVER commit this file with real values!

# ---- Wallet ----
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ---- Source Chain ----
FROM_CHAIN_ID=137          # Chain ID (137=Polygon, 1=Ethereum, 56=BSC, 42161=Arbitrum, 10=Optimism, 8453=Base)
FROM_TOKEN=USDC            # Token symbol: USDC, USDT, ETH, MATIC, WETH, DAI, etc.
FROM_AMOUNT=10             # Human-readable amount (e.g. 10 = 10 USDC)

# ---- Destination Chain ----
TO_CHAIN_ID=42161          # Can be same as FROM_CHAIN_ID for same-chain swap
TO_TOKEN=USDC              # Token to receive

# ---- Trading Parameters ----
SLIPPAGE=0.03              # Slippage tolerance (0.03 = 3%)

# ---- Auto Mode ----
AUTO_MODE=false            # true = run on schedule, false = run once
INTERVAL_MINUTES=60        # Interval between executions (only used if AUTO_MODE=true)

# ---- Custom RPC URLs (optional) ----
# Leave empty to use public RPCs
ETHEREUM_RPC=
BSC_RPC=
POLYGON_RPC=
ARBITRUM_RPC=
OPTIMISM_RPC=
AVALANCHE_RPC=
BASE_RPC=
ZKSYNC_RPC=
SCROLL_RPC=
LINEA_RPC=
